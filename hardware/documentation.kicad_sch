	(text_box "Notes\n- Cable for SUR connectors: \n  /datasheets/Cable_0-8mm_JST_SUR.pdf\n  4-pin receptable: A04SUR04SUR32W102A\n  6-pin receptable: A06SUR06SUR32W102A"
		(exclude_from_sim no)
		(at 33.02 133.35 0)
		(size 76.2 25.4)
		(margins 0.9525 0.9525 0.9525 0.9525)
